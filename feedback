<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feedback Analytics Pro - Persistent Data | Grocery & Fresho</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root { 
            --primary: #0f172a; 
            --accent: #2563eb; 
            --highlight: #fef08a; 
            --light-yellow: #fff9c4;
            --major-color: #be123c;
            --monthly-color: #059669;
            --demand-color: #7c3aed;
            --price-color: #0284c7; 
            --category-text: #1e40af; 
            --fb-color: #1877f2;
            --cust-color: #db2777;
            --staff-color: #ea580c;
            --groc-color: #16a34a;
            --fresh-color: #65a30d;
            --bill-color: #4f46e5;
            --maint-color: #854d0e;
        }
        body { font-family: 'Inter', sans-serif; background: #cbd5e1; margin: 0; padding: 10px; color: var(--primary); }
        .tabs-container { max-width: 950px; margin: 0 auto; }
        .tab-buttons { display: flex; gap: 5px; margin-bottom: 10px; background: #1e293b; padding: 10px; border-radius: 12px; flex-wrap: wrap; }
        .tab-btn { padding: 12px 25px; border: none; background: #334155; color: white; cursor: pointer; border-radius: 8px; font-weight: 800; transition: 0.3s; }
        .tab-btn.active { background: var(--accent); }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .admin-panel { background: white; padding: 30px; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); margin-bottom: 20px; }
        .input-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 15px; }
        textarea { width: 100%; padding: 15px; border: 2px solid #e2e8f0; border-radius: 10px; font-size: 14px; box-sizing: border-box; font-family: inherit; margin-bottom: 15px; }
        input, select { width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 10px; box-sizing: border-box; font-family: inherit; font-weight: 600; }
        .btn-group { display: flex; gap: 10px; flex-wrap: wrap; }
        button.action-btn { flex: 1; padding: 16px; border: none; border-radius: 10px; font-weight: 800; cursor: pointer; text-transform: uppercase; min-width: 140px; }
        .btn-add { background: var(--accent); color: white; }
        .btn-img { background: var(--primary); color: white; }
        .btn-major { background: var(--major-color); color: white; }
        .btn-summary { background: #64748b; color: white; }
        .btn-monthly { background: var(--monthly-color); color: white; }
        .btn-demand { background: var(--demand-color); color: white; }
        .btn-price { background: var(--price-color); color: white; }
        .btn-fb { background: var(--fb-color); color: white; }
        .btn-cust { background: var(--cust-color); color: white; }
        .btn-staff { background: var(--staff-color); color: white; }
        .btn-groc { background: var(--groc-color); color: white; }
        .btn-fresh { background: var(--fresh-color); color: white; }
        .btn-bill { background: var(--bill-color); color: white; }
        .btn-maint { background: var(--maint-color); color: white; }
        .btn-undo { background: #f97316; color: white; font-size: 11px; padding: 10px 15px !important; width: auto !important; flex: none !important; margin-left: 10px; }
        .btn-clear { background: #000; color: white; font-size: 11px; padding: 10px 15px !important; width: auto !important; flex: none !important; margin-left: 10px; }
        .report-preview-area { width: 100%; background: white; padding: 30px; box-sizing: border-box; position: relative; border-radius: 8px; margin-top: 15px; }
        .report-preview-area::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 8px; background: var(--accent); border-radius: 8px 8px 0 0; }
        .major-area::before { background: var(--major-color); }
        .monthly-area::before { background: var(--monthly-color); }
        .demand-area::before { background: var(--demand-color); }
        .price-area::before { background: var(--price-color); }
        .fb-area::before { background: var(--fb-color); }
        .cust-area::before { background: var(--cust-color); }
        .staff-area::before { background: var(--staff-color); }
        .groc-area::before { background: var(--groc-color); }
        .fresh-area::before { background: var(--fresh-color); }
        .bill-area::before { background: var(--bill-color); }
        .maint-area::before { background: var(--maint-color); }
        .report-header { border-bottom: 3px solid var(--primary); margin-bottom: 20px; padding-bottom: 10px; }
        .report-header h1 { margin: 0; font-size: 22px; font-weight: 800; color: #1e293b; letter-spacing: -0.5px; }
        .meta-date { text-align: right; font-size: 14px; font-weight: 800; color: var(--accent); margin-bottom: 15px; }
        .main-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; border: 2px solid #000; table-layout: fixed; }
        .main-table th { background: #f8fafc; padding: 8px 6px; font-size: 11px; border: 1.5px solid #000; text-align: left; font-weight: 900; letter-spacing: -0.2px; }
        .main-table td { padding: 8px 6px; border: 1.5px solid #000; font-size: 12px; font-weight: 700; vertical-align: middle; word-wrap: break-word; line-height: 1.3; }
        .category-heading td { background-color: #f1f5f9 !important; color: var(--category-text) !important; font-weight: 900 !important; text-transform: uppercase; border: 2px solid #000 !important; padding: 10px 6px !important; font-size: 13px !important; }
        .high-complaint-row { background-color: var(--light-yellow) !important; }
        mark { background-color: var(--highlight); color: black; padding: 1px 3px; border-radius: 3px; font-weight: 800; }
        .status-toggle-btn { width: 100%; padding: 5px 2px; border-radius: 4px; border: none; font-weight: 900; font-size: 11px; cursor: pointer; text-transform: uppercase; transition: 0.2s; }
        .status-uploaded { background: #dcfce7; color: #166534; border: 1px solid #166534; }
        .status-unuploaded { background: #fee2e2; color: #be123c; border: 1px solid #be123c; }
        .analytics-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
        .stat-card { border: 2px solid #000; padding: 10px; text-align: center; border-radius: 6px; }
        .stat-card small { font-size: 10px; font-weight: 900; display: block; color: #64748b; }
        .stat-card div { font-size: 20px; font-weight: 900; }
        .summary-box { grid-column: span 3; border: 2px solid #000; padding: 12px; background: #f0fdf4; border-radius: 8px; font-size: 12px; }
        .percentage-section { margin-top: 15px; padding: 12px; border: 2px solid #000; border-radius: 8px; }
        .percent-item { display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid #eee; font-size: 12px; font-weight: 700; }
        .footer-line { margin-top: 25px; text-align: center; font-size: 10px; font-weight: 700; opacity: 0.5; }
        .hidden { display: none; }
        .control-bar { display: flex; align-items: center; margin-bottom: 10px; gap: 10px; flex-wrap: wrap; }
        .filter-select { width: 160px; padding: 8px; border: 2px solid var(--fb-color); border-radius: 8px; font-weight: 800; background: #fff; }
        .btn-del-row { background: #be123c; color: white; border: none; padding: 3px 6px; border-radius: 4px; cursor: pointer; font-size: 10px; font-weight: 800; }
        .count-footer-wrapper { margin-top: 15px; border: 2px solid #000; padding: 10px; border-radius: 6px; background: #f8fafc; font-weight: 900; font-size: 13px; display: flex; justify-content: space-between; align-items: center; }
        .days-counter-badge { background: var(--accent); color: white; padding: 4px 10px; border-radius: 50px; font-size: 11px; font-weight: 900; text-transform: uppercase; }
        .date-badge { background: #e2e8f0; color: #334155; padding: 2px 6px; border-radius: 4px; font-size: 10px; font-weight: 800; margin-right: 4px; display: inline-block; border: 1px solid #cbd5e1; text-transform: none; }
        @media print { body { background: white; padding: 0; } .admin-panel, .tab-buttons, .control-bar, .hide-on-download { display: none !important; } .report-preview-area { border: none !important; box-shadow: none !important; margin: 0 !important; padding: 0 !important; } .tab-content { display: block !important; } .tab-content:not(.active) { display: none !important; } }
    </style>
</head>
<body>
<div class="tabs-container">
