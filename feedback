  display:block; margin-bottom:3px;
}
.doc-ref .ref-status{
  display:inline-flex; align-items:center; gap:5px; margin-

top:8px; font-size:9.5px; font-weight:800;
  text-transform:uppercase; letter-spacing:.5px; color:var(--

gold-deep); font-family:var(--sans);
}
.doc-ref .ref-status::before{
  content:""; width:6px; height:6px; border-radius:50%; 

background:var(--gold);
  box-shadow:0 0 0 3px var(--gold-pale);
}

.meta-strip{
  display:flex; gap:10px; margin-bottom:18px; flex-wrap:wrap;
}
.meta-pill{
  background:var(--ink); color:#fff; padding:7px 13px; 

border-radius:50px; font-size:11px;
  font-weight:700; display:flex; gap:6px; align-items:center; 

font-family:var(--mono);
}
.meta-pill b{ color:var(--gold); font-family:var(--sans); }
.meta-pill.accent-pill{ background:var(--gold); color:#241a06; 

}
.meta-pill.accent-pill b{ color:#241a06; }

.legend-strip{
  display:flex; align-items:center; gap:8px; font-size:10.5px; 

font-weight:700; color:var(--muted);
  margin:-6px 0 16px; font-family:var(--sans);
}
.legend-strip .swatch{ width:13px; height:13px; border-

radius:3px; display:inline-block; border:1px solid rgba

(0,0,0,.15); }

.main-table{ width:100%; border-collapse:collapse; margin-

bottom:20px; border:1.5px solid var(--ink); table-

layout:fixed; }
.main-table th{
  background:var(--ink); color:#fff; padding:10px 8px; font-

size:10.5px; border:1px solid #2a3650;
  text-align:left; font-weight:800; letter-spacing:.3px; 

text-transform:uppercase; font-family:var(--sans);
}
.main-table td{
  padding:9px 8px; border:1px solid #d7dbe2; font-size:12.5px; 

font-weight:600; vertical-align:middle;
  word-wrap:break-word; line-height:1.4; color:#1c2538;
}
.main-table tbody tr:nth-child(even){ background:#f8f9fb; }
.category-heading td{
  background:linear-gradient(90deg,#eef1f7,#f8f9fb)!important; 

color:var(--category-text)!important;
  font-weight:800!important; text-transform:uppercase; 

border:1.5px solid var(--ink)!important;
  padding:10px 8px!important; font-size:12.5px!important; 

letter-spacing:.4px;
}
.high-complaint-row{ background-color:var(--highlight)!

important; }
.high-complaint-row td{ font-weight:700; }
mark{ background-color:var(--gold-pale); color:var(--ink); 

padding:1px 4px; border-radius:3px; font-weight:800; }

.status-toggle-btn{
  width:100%; padding:6px 4px; border-radius:6px; border:none; 

font-weight:800; font-size:10.5px;
  cursor:pointer; text-transform:uppercase; transition:.2s; 

letter-spacing:.3px;
}
.status-uploaded{ background:#d6f3e3; color:#0f7a4d; 

border:1px solid #0f7a4d; }
.status-unuploaded{ background:#fde2e7; color:var(--bad); 

border:1px solid var(--bad); }

.analytics-grid{ display:grid; grid-template-columns:repeat

(3,1fr); gap:12px; }
.stat-card{
  border:1.5px solid var(--ink); padding:14px 10px; text-

align:center; border-radius:var(--radius-sm);
  background:linear-gradient(180deg,#fff,#f7f8fa);
}
.stat-card small{ font-size:9.5px; font-weight:800; 

display:block; color:var(--muted); letter-spacing:.5px; text-

