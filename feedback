<script>
    const STORAGE_VERSION = "branch_data_v2_"; 
    const globalDataStore = {};

    function saveBranchToLocalStorage(branchId) {
        if (globalDataStore[branchId]) {
            localStorage.setItem(STORAGE_VERSION + branchId, JSON.stringify(globalDataStore[branchId]));
        }
    }

    function loadBranchFromLocalStorage(branchId) {
        const saved = localStorage.getItem(STORAGE_VERSION + branchId);
        const defaultCategories = {
            monthly: [], major: [], demand: [], price: [], cust: [], staff: [], grocery: [], fresho: [], bill: [], maint: []
        };
        if (saved) {
            try {
                const parsed = JSON.parse(saved);
                for (let key in defaultCategories) {
                    if (!parsed[key]) parsed[key] = [];
                }
                globalDataStore[branchId] = parsed;
            } catch(e) { globalDataStore[branchId] = { ...defaultCategories }; }
        } else {
            globalDataStore[branchId] = { ...defaultCategories };
        }
    }

    function initStoreForBranch(branchId) {
        if (!globalDataStore[branchId]) {
            loadBranchFromLocalStorage(branchId);
        }
    }

    function refreshAllBranchViews(branchId) {
        if (!globalDataStore[branchId]) return;
        renderGroupedMonthlyTable(branchId);
        renderAllTables(branchId);
    }

    const getBranchNum = (id) => id.replace('tab', '');
    
    function buildBranchTemplate(id) {
        const bNum = getBranchNum(id);
        return `<div class="admin-panel"><h2 style="margin-top:0; font-weight: 800; color: var(--accent);">REPORT CONSOLE (BRANCH ${bNum})</h2><div class="input-row"><input type="text" id="branchInput_${id}" placeholder="Main Heading (Dates)"><input type="date" id="dateInput_${id}"><input type="number" id="totalFeedbackInput_${id}" placeholder="Total Overall FB"></div><textarea id="bulkInput_${id}" rows="8" placeholder="Category Name\nProduct. Reason"></textarea><textarea id="goodCommentsInput_${id}" rows="2" placeholder="Summary / Remarks..."></textarea><div class="btn-group"><button class="action-btn btn-summary" onclick="switchPage('${id}', 'summary')">Summary Report</button><button class="action-btn btn-monthly" onclick="switchPage('${id}', 'monthly')">Monthly Data</button><button class="action-btn btn-major" onclick="switchPage('${id}', 'major')">Major Complaints</button><button class="action-btn btn-demand" onclick="switchPage('${id}', 'demand')">Demands & Stock</button><button class="action-btn btn-price" onclick="switchPage('${id}', 'price')">Price Issues</button><button class="action-btn btn-cust" onclick="switchPage('${id}', 'cust')">Satisfaction</button><button class="action-btn btn-staff" onclick="switchPage('${id}', 'staff')">Staff</button><button class="action-btn btn-groc" onclick="switchPage('${id}', 'grocery')">Grocery</button><button class="action-btn btn-fresh" onclick="switchPage('${id}', 'fresho')">Fresho</button><button class="action-btn btn-bill" onclick="switchPage('${id}', 'bill')">Billing</button><button class="action-btn btn-maint" onclick="switchPage('${id}', 'maint')">Maintenance</button><button class="action-btn btn-add" onclick="processData('${id}')">Generate Report</button></div></div><div id="pageSummary_${id}"><button class="action-btn btn-img" style="margin-bottom:10px; width:200px" onclick="downloadImage('pdfArea_${id}')">Download PNG (HD)</button><div id="pdfArea_${id}" class="report-preview-area"><div class="report-header"><h1 id="mainHeading_${id}">ANALYSIS REPORT</h1></div><div class="meta-date">DATE: <span id="outDate_${id}">--/--/----</span></div><table class="main-table"><thead><tr><th style="width: 35%;">PRODUCT</th><th style="width: 15%; text-align: center;">QTY</th><th style="width: 50%;">REASONS / COMPLAINTS</th></tr></thead><tbody id="tableBody_${id}"></tbody></table><div class="analytics-grid"><div class="stat-card"><small>TOTAL ISSUES</small><div id="outTotalComplaints_${id}">0</div></div><div class="stat-card"><small>TOTAL FB</small><div id="outTotalAll_${id}">0</div></div><div class="stat-card"><small>SCORE</small><div id="outSatRate_${id}" style="color:var(--accent)">0%</div></div><div class="summary-box"><small style="font-weight:900; color:#166534">SUMMARY & REMARKS</small><p id="outGoodComments_${id}">...</p></div></div><div class="percentage-section"><h3 style="margin:0 0 10px; font-size:13px; font-weight:900;">ISSUE DISTRIBUTION</h3><div id="percentageList_${id}"></div></div><div class="footer-line">Analytical Intelligence System • Confidential</div></div></div><div id="pageMonthly_${id}" class="hidden"><div class="control-bar"><button class="action-btn btn-summary" style="width:220px; background:var(--monthly-color)" onclick="downloadPDF()">Download Monthly PDF</button><button class="action-btn btn-undo" onclick="undoLastEntry('${id}', 'monthly')">UNDO LAST ENTRY</button><button class="action-btn btn-clear" onclick="clearSpecificData('${id}', 'monthly')">CLEAR ALL</button></div><div id="monthlyArea_${id}" class="report-preview-area monthly-area"><div class="report-header" style="border-bottom-color:var(--monthly-color)"><h1 id="monthlyHeading_${id}">BRANCH ${bNum} MONTHLY DATA</h1></div><table class="main-table" id="monthlyTable_${id}"><thead><tr><th style="width: 20%;">DATE(S)</th><th style="width: 30%;">PRODUCT NAME</th><th style="width: 12%; text-align: center;">TOTAL QTY</th><th style="width: 30%;">REASONS (UNIQUE)</th><th class="hide-on-download" style="width: 8%;