    function switchFbPage(pageType) { document.getElementById('fbPageMpk').classList.toggle('hidden', pageType !== 'mpk'); document.getElementById('fbPageHyd').classList.toggle('hidden', pageType !== 'hyd'); renderFbTables(); }
    function processFbData() { const targetPage = document.getElementById('fbTargetPage').value; const rawDate = document.getElementById('fbDateInput').value; const fbStatus = document.getElementById('fbStatusInput').value; if(!rawDate) { alert("Select date!"); return; } const fbDate = rawDate.split("-").reverse().join("/"); const extractedMonth = rawDate.split("-")[1]; let dataStore = JSON.parse(localStorage.getItem(`fb_${targetPage}_data`)||[]); dataStore.push({ rawDateValue:rawDate, date:fbDate, month:extractedMonth, city:targetPage.toUpperCase(), status:fbStatus }); localStorage.setItem(`fb_${targetPage}_data`, JSON.stringify(dataStore)); renderFbTables(); alert("Facebook Entry Saved"); }
    function renderFbTables() { const mpkBody = document.getElementById('fbMpkTableBody'); let mpkData = JSON.parse(localStorage.getItem('fb_mpk_data')||[]); mpkData.sort((a,b)=>new Date(a.rawDateValue)-new Date(b.rawDateValue)); let mpkUploads=0,mpkUnuploads=0; mpkBody.innerHTML=""; mpkData.forEach((item,idx)=>{ if(item.status==='Uploaded') mpkUploads++; else mpkUnuploads++; mpkBody.innerHTML+=`<tr><td>${item.date}</td><td>MPK Page</td><td style="text-align:center"><button class="status-toggle-btn ${item.status==='Uploaded'?'status-uploaded':'status-unuploaded'}" onclick="toggleFbStatus('mpk',${idx})">${item.status}</button></td><td class="hide-on-download"><button class="btn-del-row" onclick="deleteFbRow('mpk',${idx})">DEL</button></td></tr>`; }); document.getElementById('mpkUploadCount').innerText=mpkUploads; document.getElementById('mpkUnuploadCount').innerText=mpkUnuploads; const hydBody = document.getElementById('fbHydTableBody'); let hydData = JSON.parse(localStorage.getItem('fb_hyd_data')||[]); hydData.sort((a,b)=>new Date(a.rawDateValue)-new Date(b.rawDateValue)); let hydUploads=0,hydUnuploads=0; hydBody.innerHTML=""; hydData.forEach((item,idx)=>{ if(item.status==='Uploaded') hydUploads++; else hydUnuploads++; hydBody.innerHTML+=`<tr><td>${item.date}</td><td>HYD Page</td><td style="text-align:center"><button class="status-toggle-btn ${item.status==='Uploaded'?'status-uploaded':'status-unuploaded'}" onclick="toggleFbStatus('hyd',${idx})">${item.status}</button></td><td class="hide-on-download"><button class="btn-del-row" onclick="deleteFbRow('hyd',${idx})">DEL</button></td></tr>`; }); document.getElementById('hydUploadCount').innerText=hydUploads; document.getElementById('hydUnuploadCount').innerText=hydUnuploads; }
    function toggleFbStatus(pageType, idx) { let data = JSON.parse(localStorage.getItem(`fb_${pageType}_data`)||[]); data.sort((a,b)=>new Date(a.rawDateValue)-new Date(b.rawDateValue)); data[idx].status = data[idx].status==='Uploaded'?'Unuploaded':'Uploaded'; localStorage.setItem(`fb_${pageType}_data`, JSON.stringify(data)); renderFbTables(); }
    function deleteFbRow(pageType, idx) { if(confirm("Delete entry?")) { let data = JSON.parse(localStorage.getItem(`fb_${pageType}_data`)||[]); data.sort((a,b)=>new Date(a.rawDateValue)-new Date(b.rawDateValue)); data.splice(idx,1); localStorage.setItem(`fb_${pageType}_data`, JSON.stringify(data)); renderFbTables(); } }
    function undoLastFbEntry(pageType) { let data = JSON.parse(localStorage.getItem(`fb_${pageType}_data`)||[]); if(data.length) { data.pop(); localStorage.setItem(`fb_${pageType}_data`, JSON.stringify(data)); renderFbTables(); alert("Last entry undone"); } else alert("No entries"); }
    function clearFbData(pageType) { if(confirm(`Clear all ${pageType} data?`)) { localStorage.removeItem(`fb_${pageType}_data`); renderFbTables(); } }
    function downloadImage(elementId) { const el = document.getElementById(elementId); const del = el.querySelectorAll('.hide-on-download'); del.forEach(d=>d.style.display='none'); html2canvas(el, { scale:2, backgroundColor:"#ffffff" }).then(canvas=>{ const link=document.createElement('a'); link.download=`${elementId}.png`; link.href=canvas.toDataURL(); link.click(); del.forEach(d=>d.style.display=''); }).catch(()=>del.forEach(d=>d.style.display='')); }
    function downloadPDF() { window.print(); }
    function openTab(evt, tabName) { [...document.getElementsByClassName("tab-content")].forEach(c => c.classList.remove("active")); [...document.getElementsByClassName("tab-btn")].forEach(b => b.classList.remove("active")); document.getElementById(tabName).classList.add("active"); evt.currentTarget.classList.add("active"); if (tabName === 'tabFacebook') renderFbTables(); else { const activeTab = ['tab1','tab2','tab3','tab4'].find(t => t === tabName); if(activeTab) refreshAllBranchViews(activeTab); } }

    loadAllBranches();
</script>
