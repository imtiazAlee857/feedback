/* 

============================================================
   DATE-WINDOW CLUSTER ENGINE
   For each product, looks at every individual complaint entry
   (date + branch) across all 4 branches, and groups entries
   into clusters where the entries fall within N days of each
   other AND span 2+ different branches. This answers: "in the
   last 20 days, which branches got the SAME complaint?"
   

============================================================ 

*/
function renderDateWindowClusters(monthVal) {
    const container = document.getElementById

('subClusterContainer');
    const emptyEl = document.getElementById

('subClusterEmpty');
    const windowLabelEl = document.getElementById

('subWindowLabel');
    if (!container) return;

    const windowEl = document.getElementById('subDateWindow');
    const minBranchesEl = document.getElementById

('subMinBranches');
    const windowDays = parseInt(windowEl ? windowEl.value : 

20) || 20;
    const minBranches = parseInt(minBranchesEl ? 

minBranchesEl.value : 2) || 2;
    if (windowLabelEl) windowLabelEl.innerText = windowDays;

    const branchIds = ['tab1','tab2','tab3','tab4'];
    branchIds.forEach(initStoreForBranch);

    // Collect every single entry, tagged with branch + parsed 

date
    // product (normalized) -> [{branch, date, dateObj, qty, 

reason}, ...]
    const productEntries = new Map();
    branchIds.forEach(id => {
        const bNum = getBranchNum(id);
        const store = globalDataStore[id];
        if (!store || !store.monthly) return;
        for (const entry of store.monthly) {
            if (!entry.product || !entry.date) continue;
            if (!matchesMonth(entry.date, monthVal)) continue;
            const prodNorm = entry.product.trim().toLowerCase

();
            if (!productEntries.has(prodNorm)) 

productEntries.set(prodNorm, { product: entry.product, list: 

[] });
            productEntries.get(prodNorm).list.push({
                branch: bNum,
                date: entry.date,
                dateObj: parseCustomDate(entry.date),
                qty: entry.qty,
                reason: entry.reason
            });
        }
    });

    const windowMs = windowDays * 24 * 60 * 60 * 1000;
    const allClusters = []; // { product, branchSet, entries: 

[...], minDate, maxDate }

    productEntries.forEach(({ product, list }) => {
        if (list.length < 2) return;
        // Sort entries chronologically
        const sorted = [...list].sort((a, b) => a.dateObj - 

b.dateObj);

        // Sliding window clustering: greedily group entries 

whose date
        // falls within `windowDays` of the cluster's earliest 

entry.
        let clusterStartIdx = 0;
        for (let i = 0; i < sorted.length; i++) {
            // Try extending current cluster
            while (clusterStartIdx < i && (sorted[i].dateObj - 

sorted[clusterStartIdx].dateObj) > windowMs) {
                clusterStartIdx++;
            }
        }
        // Build clusters via expanding window scan
        let used = new Array(sorted.length).fill(false);
        for (let i = 0; i < sorted.length; i++) {
            if (used[i]) continue;
            let clusterEntries = [sorted[i]];
            used[i] = true;
            for (let j = i + 1; j < sorted.length; j++) {
                if (used[j]) continue;
                if ((sorted[j].dateObj - sorted[i].dateObj) <= 

windowMs) {
                    clusterEntries.push(sorted[j]);
                    used[j] = true;
                }
            }
            const branchSet = new Set(clusterEntries.map(e => 

e.branch));
            if (branchSet.size >= minBranches) {
                const dates = clusterEntries.map(e => 

e.dateObj);
                allClusters.push({
                    product,
                    branchSet,
                    entries: clusterEntries,
                    minDate: new Date(Math.min(...dates)),
                    maxDate: new Date(Math.max(...dates))
                });
            }
        }
    });

    // Sort clusters: most branches first, then most entries
    allClusters.sort((a, b) => (b.branchSet.size - 

a.branchSet.size) || (b.entries.length - a.entries.length));

    if (allClusters.length === 0) {
        container.innerHTML = "";
        emptyEl.classList.remove('hidden');
        return;
    }
    emptyEl.classList.add('hidden');

    const fmtDate = (d) => `${String(d.getDate()).padStart

(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}/

${d.getFullYear()}`;

    container.innerHTML = allClusters.map(c => {
        // group entries by branch for display
        const byBranch = new Map();
        c.entries.forEach(e => {
            if (!byBranch.has(e.branch)) byBranch.set

(e.branch, []);
            byBranch.get(e.branch).push(e);
        });
        const branchRows = Array.from(byBranch.entries())
            .sort((a,b) => a[0] - b[0])
            .map(([b, entries]) => {
                const dateChips = entries.map(e => `<span 

class="date-chip">${e.date} &middot; qty ${e.qty}

</span>`).join(" ");
                return `<div class="cluster-branch-row"><span 

class="branch-badge">B${b}</span> ${dateChips}</div>`;
            }).join("");

        const spanDays = Math.round((c.maxDate - c.minDate) / 

(24*60*60*1000));

        return `<div class="cluster-block">
            <div class="cluster-head">
                <span class="cname">${c.product} &mdash; 

${c.branchSet.size} branches hit</span>
                <span class="cwindow">${fmtDate(c.minDate)} 

&rarr; ${fmtDate(c.maxDate)} (${spanDays} day span)</span>
            </div>
            <div class="cluster-body">${branchRows}</div>
        </div>`;
    }).join("");
}

