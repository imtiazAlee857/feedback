/* 

============================================================
   SUB COMPLAINTS  cross-branch recurrence engine
   Scans each branch's `monthly` (already-aggregated) data,
   groups by normalized product name across ALL branches,
   and surfaces only products reported by 2+ branches (or
   whatever threshold is selected). Read-only / derived view 
   does not write to globalDataStore.
   

============================================================ 

*/
function renderSubComplaints() {
    const minBranchesEl = document.getElementById

('subMinBranches');
    const sortModeEl = document.getElementById('subSortMode');
    const headingEl = document.getElementById

('subHeadingInput');
    const monthFilterEl = document.getElementById

('subMonthFilter');
    const tbody = document.getElementById('subTableBody');
    if (!tbody) return; // sub complaints tab not yet built / 

not relevant

    const minBranches = parseInt(minBranchesEl ? 

minBranchesEl.value : 2) || 2;
    const sortMode = sortModeEl ? sortModeEl.value : 

'branches';
    const monthVal = monthFilterEl ? monthFilterEl.value : 

'all';
    const branchIds = ['tab1','tab2','tab3','tab4'];

    branchIds.forEach(initStoreForBranch);

    // product (normalized) -> { product, totalQty, 

branchQty:Map(branchLabel->qty), reasonsSet, branchSet }
    const productMap = new Map();

    branchIds.forEach(id => {
        const bNum = getBranchNum(id);
        const store = globalDataStore[id];
        if (!store || !store.monthly) return;
        for (const entry of store.monthly) {
            if (!entry.product) continue;
            if (!matchesMonth(entry.date, monthVal)) continue;
            const prodNorm = entry.product.trim().toLowerCase

();
            if (!productMap.has(prodNorm)) {
                productMap.set(prodNorm, {
                    product: entry.product,
                    totalQty: 0,
                    branchQty: new Map(),
                    reasonsSet: new Set(),
                    branchSet: new Set()
                });
            }
            const grp = productMap.get(prodNorm);
            grp.totalQty += entry.qty;
            grp.branchSet.add(bNum);
            grp.branchQty.set(bNum, (grp.branchQty.get(bNum) 

|| 0) + entry.qty);
            if (entry.reason) grp.reasonsSet.add

(entry.reason);
        }
    });

    // Filter: only products that appear in >= minBranches 

distinct branches
    let matched = Array.from(productMap.values()).filter(g => 

g.branchSet.size >= minBranches);

    // Sort
    if (sortMode === 'branches') {
        matched.sort((a, b) => (b.branchSet.size - 

a.branchSet.size) || (b.totalQty - a.totalQty));
    } else if (sortMode === 'qty') {
        matched.sort((a, b) => b.totalQty - a.totalQty);
    } else if (sortMode === 'az') {
        matched.sort((a, b) => a.product.localeCompare

(b.product));
    }

    // Render heading
    const headingOut = document.getElementById

('subHeadingOut');
    if (headingOut) {
        const customHeading = headingEl && 

headingEl.value.trim();
        headingOut.innerText = customHeading ? 

customHeading.toUpperCase() : "SUB COMPLAINTS  CROSS-BRANCH 

REPORT";
    }
    const genDate = document.getElementById

('subGeneratedDate');
    const today = new Date();
    if (genDate) {
        genDate.innerText = `${String(today.getDate

()).padStart(2,'0')}/${String(today.getMonth()+1).padStart

(2,'0')}/${today.getFullYear()}`;
    }
    const refCode = document.getElementById('subRefCode');
    if (refCode) {
        const stamp = `${today.getFullYear()}${String

(today.getMonth()+1).padStart(2,'0')}${String(today.getDate

()).padStart(2,'0')}`;
        refCode.innerText = `RPT\u00B7SUB\u00B7${stamp}`;
    }

    // Render rows
    tbody.innerHTML = "";
    let combinedQty = 0;
    let allBranchCount = 0;
    const branchContribution = { '1':0, '2':0, '3':0, '4':0 };

    matched.forEach((g, idx) => {
        combinedQty += g.totalQty;
        if (g.branchSet.size >= 4) allBranchCount++;
        g.branchQty.forEach((q, b) => { branchContribution[b] 

= (branchContribution[b] || 0) + q; });

        const branchBadges = Array.from(g.branchQty.keys())
            .sort((a,b) => a - b)
            .map(b => `<span class="branch-badge">B${b}

</span>`)
            .join("");

        const perBranchQty = Array.from(g.branchQty.entries())
            .sort((a,b) => a[0] - b[0])
            .map(([b, q]) => `<span class="date-badge">B${b}: 

${q}</span>`)
            .join("");

        let reasonsArr = Array.from(g.reasonsSet);
        let reasonsDisplay = reasonsArr.slice(0, 5).join("; 

");
        if (reasonsArr.length > 5) reasonsDisplay += ` +

${reasonsArr.length - 5} more`;

        let recurClass = g.branchSet.size >= 4 ? 'recur-4' : 

(g.branchSet.size === 3 ? 'recur-3' : 'recur-2');
        let rowHighlight = g.branchSet.size >= 4 ? 

'class="high-complaint-row"' : '';

        tbody.innerHTML += `<tr ${rowHighlight}>
            <td style="text-align:center;"><span class="rank-

chip${idx===0?' rank-1':idx===1?' rank-2':idx===2?' rank-

3':''}">${idx + 1}</span></td>
            <td style="font-weight:800;">${g.product}</td>
            <td style="text-align:center;">
