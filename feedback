        <div id="fbPageMpk"><div class="control-bar"><select id="fbMpkMonthFilter" class="filter-select" onchange="renderFbTables()"><option value="all">All Months</option><option value="01">January</option><option value="02">February</option><option value="03">March</option><option value="04">April</option><option value="05">May</option><option value="06">June</option><option value="07">July</option><option value="08">August</option><option value="09">September</option><option value="10">October</option><option value="11">November</option><option value="12">December</option></select><button class="action-btn btn-img" style="width:220px; background:var(--fb-color)" onclick="downloadImage('fbAreaMpk')">Download MPK PNG (HD)</button><button class="action-btn btn-undo" onclick="undoLastFbEntry('mpk')">UNDO LAST ENTRY</button><button class="action-btn btn-clear" onclick="clearFbData('mpk')">CLEAR ALL MPK</button></div><div id="fbAreaMpk" class="report-preview-area fb-area"><div class="report-header" style="border-bottom-color:var(--fb-color)"><h1>FACEBOOK PRICE LIST UPDATE - MPK PAGE</h1></div><div class="analytics-grid" style="margin-bottom:20px;"><div class="stat-card" style="border-color: #166534;"><small>TOTAL UPLOADED</small><div id="mpkUploadCount" style="color:#166534">0</div></div><div class="stat-card" style="border-color: #be123c;"><small>TOTAL UNUPLOADED</small><div id="mpkUnuploadCount" style="color:#be123c">0</div></div></div><table class="main-table"><thead><tr><th style="width: 30%;">DATE</th><th style="width: 30%;">PAGE</th><th style="width: 25%; text-align: center;">STATUS</th><th class="hide-on-download" style="width: 15%; text-align: center;">DEL</th></tr></thead><tbody id="fbMpkTableBody"></tbody></table><div class="footer-line">Facebook Operations Audit • Confidential</div></div></div>
