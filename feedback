    function normalizeText(str) { if (!str) return ""; let txt = str.trim().toLowerCase(); return txt.charAt(0).toUpperCase() + txt.slice(1); }

    // Helper to parse DD/MM/YYYY to Date object for strict sorting
    function parseCustomDate(dateStr) {
        if(!dateStr) return new Date(0);
        const parts = dateStr.split("/");
        if(parts.length === 3) {
            return new Date(parts[2], parts[1] - 1, parts[0]);
        }
        return new Date(dateStr);
    }

    function processData(id) {
        initStoreForBranch(id);
        const heading = document.getElementById(`branchInput_${id}`).value || "ANALYSIS REPORT";
        const rawDate = document.getElementById(`dateInput_${id}`).value;
        const totalFb = parseInt(document.getElementById(`totalFeedbackInput_${id}`).value) || 0;
        const bulkText = document.getElementById(`bulkInput_${id}`).value;
        const remarks = document.getElementById(`goodCommentsInput_${id}`).value;
        if (!rawDate) { alert("Please select a date!"); return; }
        if (bulkText.trim() === "") { alert("Please input complaints data!"); return; }
        const formattedDate = rawDate.split("-").reverse().join("/");
        document.getElementById(`mainHeading_${id}`).innerText = heading;
        document.getElementById(`outDate_${id}`).innerText = formattedDate;
        document.getElementById(`outTotalAll_${id}`).innerText = totalFb;
        document.getElementById(`outGoodComments_${id}`).innerText = remarks || "...";
        const tbody = document.getElementById(`tableBody_${id}`); tbody.innerHTML = "";
        const lines = bulkText.split("\n");
        let categoriesOrder = [], dataMap = {};
        let currentCategory = "", grocCount = 0, freshCount = 0, otherCount = 0;
        lines.forEach(line => {
            let cleanLine = line.trim();
            if (!cleanLine) return;
            if (!cleanLine.includes(".") && !cleanLine.includes("-") && !cleanLine.match(/^\d/)) {
                currentCategory = normalizeText(cleanLine);
                if (!categoriesOrder.includes(currentCategory)) categoriesOrder.push(currentCategory);
                if (!dataMap[currentCategory]) dataMap[currentCategory] = {};
                return;
            }
            cleanLine = cleanLine.replace(/^[-*\d]+\s*/, '');
            let productPart = "", reasonPart = "";
            if (cleanLine.includes(".")) {
                let dotIdx = cleanLine.indexOf(".");
                productPart = normalizeText(cleanLine.substring(0, dotIdx));
                reasonPart = normalizeText(cleanLine.substring(dotIdx+1));
            } else { productPart = normalizeText(cleanLine); reasonPart = "General issue"; }
            if (!currentCategory) { currentCategory = "Others"; if (!categoriesOrder.includes(currentCategory)) categoriesOrder.push(currentCategory); if (!dataMap[currentCategory]) dataMap[currentCategory] = {}; }
            let catLower = currentCategory.toLowerCase();
            if(catLower.includes("grocery") || catLower.includes("groc")) grocCount++;
            else if(catLower.includes("fresho") || catLower.includes("fresh")) freshCount++;
            else otherCount++;
            let key = `${productPart.toLowerCase()}||${reasonPart.toLowerCase()}`;
            if (dataMap[currentCategory][key]) dataMap[currentCategory][key].qty += 1;
            else dataMap[currentCategory][key] = { qty:1, originalProduct: productPart, originalReason: reasonPart };
        });
        let totalIssuesCount = 0;
        for (let category of categoriesOrder) {
            const combos = dataMap[category];
            if (!combos || Object.keys(combos).length === 0) continue;
            const productGroups = new Map();
            for (let combo of Object.values(combos)) {
                const prodNorm = combo.originalProduct.toLowerCase();
                if (!productGroups.has(prodNorm)) productGroups.set(prodNorm, { product: combo.originalProduct, totalQty: 0, reasonsSet: new Set() });
                const group = productGroups.has(prodNorm) ? productGroups.get(prodNorm) : null;
                group.totalQty += combo.qty;
                group.reasonsSet.add(combo.originalReason);
                totalIssuesCount += combo.qty;
                
                globalDataStore[id].monthly.push({ date: formattedDate, product: combo.originalProduct, qty: combo.qty, reason: combo.originalReason });
                let routeData = { product: combo.originalProduct, qty: combo.qty, reason: combo.originalReason };
                let reasonLow = combo.originalReason.toLowerCase(), catLow = category.toLowerCase();
                const pricePhrases = ["price expensive", "prices expensive", "price diff", "price issue", "price tags issue"];
                let isPrice = pricePhrases.some(p => reasonLow.includes(p));
                
                if (isPrice) globalDataStore[id].price.push({ date: formattedDate, ...routeData });
                else if (reasonLow.includes("unavailable") || reasonLow.includes("short") || reasonLow.includes("magwai")) globalDataStore[id].demand.push({ date: formattedDate, ...routeData });
                else if (catLow.includes("grocery") || catLow.includes("groc")) globalDataStore[id].grocery.push({ date: formattedDate, ...routeData });
                else if (catLow.includes("fresho") || catLow.includes("fresh")) globalDataStore[id].fresho.push({ date: formattedDate, ...routeData });
                else if (catLow.includes("staff")) globalDataStore[id].staff.push({ date: formattedDate, ...routeData });
                else if (catLow.includes("maintenance") || catLow.includes("maint")) globalDataStore[id].maint.push({ date: formattedDate, ...routeData });
                else if (catLow.includes("satisfaction") || catLow.includes("sat") || combo.originalProduct.toLowerCase().includes("customer")) globalDataStore[id].cust.push({ date: formattedDate, ...routeData });
                else if (catLow.includes("billing") || catLow.includes("bill")) globalDataStore[id].bill.push({ date: formattedDate, ...routeData });
            }
            tbody.innerHTML += `<tr class="category-heading"><td colspan="3">${category} Complaints</td></tr>`;
            for (let group of productGroups.values()) {
                let reasonsArray = Array.from(group.reasonsSet);
                let displayReasons = reasonsArray.slice(0,4).join("; ");
                if (reasonsArray.length > 4) displayReasons += ` +${reasonsArray.length-4} more`;
                let highlightClass = group.totalQty > 2 ? 'class="high-complaint-row"' : '';
                tbody.innerHTML += `<tr ${highlightClass}><td style="font-weight:800;">${group.product}</td><td style="text-align:center; font-weight:900; color:var(--accent);">${group.totalQty}</td><td>${displayReasons}</td></tr>`;
                
                if (group.totalQty > 2) {
                    globalDataStore[id].major.push({ date: formattedDate, product: group.product, qty: group.totalQty, reason: displayReasons });
                }
            }
        }
        document.getElementById(`outTotalComplaints_${id}`).innerText = totalIssuesCount;
        const score = totalFb > 0 ? Math.round(((totalFb - totalIssuesCount)/totalFb)*100) : 100;
        document.getElementById(`outSatRate_${id}`).innerText = `${score}%`;
        let grossSum = grocCount+freshCount+otherCount;
        let grocPercent = grossSum?Math.round((grocCount/grossSum)*100):0, freshPercent = grossSum?Math.round((freshCount/grossSum)*100):0, otherPercent = grossSum?Math.round((otherCount/grossSum)*100):0;
        document.getElementById(`percentageList_${id}`).innerHTML = `<div class="percent-item"><span>Grocery Complaints:</span><span>${grocPercent}%</span></div><div class="percent-item"><span>Fresho Complaints:</span><span>${freshPercent}%</span></div><div class="percent-item"><span>Others Complaints:</span><span>${otherPercent}%</span></div>`;
        saveBranchToLocalStorage(id);
        refreshAllBranchViews(id);
        alert("Report processed! Yellow highlighted rows have been pushed to Major page successfully.");
    }

    function renderGroupedMonthlyTable(id) {
        initStoreForBranch(id);
        const store = globalDataStore[id];
        const tbody = document.getElementById(`monthlyTableBody_${id}`);
        const totalSpan = document.getElementById(`monthlyTotalCount_${id}`);
        const daysSpan = document.getElementById(`monthlyDaysCount_${id}`);
        if(!tbody) return;

        // --- Logic 2: Sorting array before rendering ---
        if (store.monthly) {
            store.monthly.sort((a, b) => parseCustomDate(a.date) - parseCustomDate(b.date));
        }

        // --- Logic 1: Extract and Count Unique Dates ---
        const uniqueDates = [...new Set(store.monthly.map(item => item.date))];
        if (daysSpan) daysSpan.innerText = `${uniqueDates.length} DAYS DATA`;

        const productMap = new Map();
        for(let entry of store.monthly) {
            let prodNorm = entry.product.toLowerCase();
            if(!productMap.has(prodNorm)) productMap.set(prodNorm, { product: entry.product, totalQty: 0, reasonsSet: new Set(), datesSet: new Set() });
            let group = productMap.get(prodNorm);
            group.totalQty += entry.qty;
            group.reasonsSet.add(entry.reason);
            if(entry.date) group.datesSet.add(entry.date.split("/").slice(0,2).join("/"));
        }
        tbody.innerHTML = "";
        let overallTotal = 0;
        for(let group of productMap.values()) {
            overallTotal += group.totalQty;
            let reasonsArr = Array.from(group.reasonsSet);
            let reasonsDisplay = reasonsArr.slice(0,4).join("; ");
            if(reasonsArr.length > 4) reasonsDisplay += ` +${reasonsArr.length-4} more`;
            let datesDisplay = Array.from(group.datesSet).map(d => `<span class="date-badge">${d}</span>`).join("");
            let highlight = group.totalQty > 2 ? 'class="high-complaint-row"' : '';
            tbody.innerHTML += `<tr ${highlight}><td>${datesDisplay}</td><td style="font-weight:800;">${group.product}</td><td style="text-align:center; font-weight:900;">${group.totalQty}</td><td>${reasonsDisplay}</td><td class="hide-on-download"><button class="btn-del-row" onclick="deleteMonthlyGroup('${id}', '${group.product.replace(/'/g, "\\'")}')">DEL</button></td></tr>`;
        }
        if(totalSpan) totalSpan.innerText = overallTotal;
    }

    function deleteMonthlyGroup(id, productName) {
        if(confirm(`Delete ALL records for product "${productName}" from Monthly log?`)) {
            initStoreForBranch(id);
            globalDataStore[id].monthly = globalDataStore[id].monthly.filter(entry => entry.product.toLowerCase() !== productName.toLowerCase());
            saveBranchToLocalStorage(id);
            refreshAllBranchViews(id);
        }
    }

    function renderAllTables(id) {
        const store = globalDataStore[id];
        const categories = ['staff','cust','bill','maint','major','demand','price','grocery','fresho'];
        categories.forEach(cat => {
            const body = document.getElementById(`${cat}TableBody_${id}`);
            const counter = document.getElementById(`${cat}TotalCount_${id}`);
            const daysSpan = document.getElementById(`${cat}DaysCount_${id}`);
            if(!body) return;
            const items = store[cat] || [];

            // --- Logic 2: Sequence dates automatically (1, 2, 3...) ---
            items.sort((a, b) => parseCustomDate(a.date) - parseCustomDate(b.date));

            // --- Logic 1: Days Counter for specific categories ---
            const uniqueDates = [...new Set(items.map(item => item.date))];
            if (daysSpan) daysSpan.innerText = `${uniqueDates.length} DAYS DATA`;

            body.innerHTML = "";
            let total = 0;
            items.forEach((item, idx) => {
                total += item.qty;
                body.innerHTML += `<tr><td>${item.date || ''}</td><td>${item.product}</td><td style="text-align:center;">${item.qty}</td><td>${item.reason}</td><td class="hide-on-download"><button class="btn-del-row" onclick="deleteRoutedRow('${id}','${cat}',${idx})">DEL</button></td></tr>`;
            });
            if(counter) counter.innerText = total;
        });
    }

    function deleteRoutedRow(id, pageName, index) {
        if(confirm("Delete this record?")) {
            initStoreForBranch(id);
            if(globalDataStore[id][pageName] && globalDataStore[id][pageName][index]) {
                globalDataStore[id][pageName].splice(index,1);
                saveBranchToLocalStorage(id);
                refreshAllBranchViews(id);
            }
        }
    }

    function undoLastEntry(id, page) {
        initStoreForBranch(id);
        if(globalDataStore[id][page]?.length) {
            globalDataStore[id][page].pop();
            saveBranchToLocalStorage(id);
            refreshAllBranchViews(id);
            alert(`Last entry removed from ${page}`);
        } else alert("No entries to undo.");
    }

    function clearSpecificData(id, page) {
        if(confirm(`Clear all ${page} data?`)) {
            initStoreForBranch(id);
            globalDataStore[id][page] = [];
            saveBranchToLocalStorage(id);
            refreshAllBranchViews(id);
        }
    }

