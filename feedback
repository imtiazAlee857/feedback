    function switchPage(id, page) {
        const pages = ['summary','monthly','major','demand','price','cust','staff','grocery','fresho','bill','maint'];
        pages.forEach(p => {
            const el = document.getElementById(`page${p.charAt(0).toUpperCase() + p.slice(1)}_${id}`);
