  border-radius:var(--radius-sm); font-size:12.5px;
}
.summary-box small{ letter-spacing:.5px; }
.summary-box p{ margin:6px 0 0; line-height:1.5; 

color:#1c2538; }
.percentage-section{ margin-top:16px; padding:14px 16px; 

border:1.5px solid var(--ink); border-radius:var(--radius-sm); 

background:#fafbfc; }
.percentage-section h3{ margin:0 0 10px; font-size:12.5px; 

font-weight:800; font-family:var(--sans); text-

transform:uppercase; letter-spacing:.4px; color:var(--ink); }
.percent-item{ display:flex; justify-content:space-between; 

padding:7px 0; border-bottom:1px dashed #d7dbe2; font-

size:12.5px; font-weight:700; }
.percent-item:last-child{ border-bottom:none; }
.percent-bar-wrap{ flex:1; margin:0 12px; background:#e7eaf0; 

border-radius:6px; height:8px; align-self:center; 

position:relative; overflow:hidden; }
.percent-bar-fill{ position:absolute; left:0; top:0; bottom:0; 

border-radius:6px; background:linear-gradient(90deg,var(--

gold-deep),var(--gold)); }

.footer-line{
  margin-top:26px; text-align:center; font-size:9.5px; font-

weight:700; color:var(--muted);
  letter-spacing:.6px; text-transform:uppercase; border-

top:1px solid #e7eaf0; padding-top:12px;
  font-family:var(--mono);
}
.hidden{ display:none; }

/* ---------- Control bar (table tools) ---------- */
.control-bar{ display:flex; align-items:center; margin-

bottom:10px; gap:9px; flex-wrap:wrap; }
.filter-select{
  width:170px; padding:9px 10px; border:1.5px solid var(--fb-

color); border-radius:var(--radius-md);
  font-weight:700; background:#fff; font-size:12.5px;
}
.btn-del-row{ background:var(--bad); color:#fff; border:none; 

padding:4px 8px; border-radius:5px; cursor:pointer; font-

size:10px; font-weight:800; }

.count-footer-wrapper{
  margin-top:16px; border:1.5px solid var(--ink); padding:12px 

