<style>
/* 

============================================================
   DESIGN TOKENS  Operations Audit System
   

============================================================ 

*/
:root{
  --ink:#0b1220;
  --ink-soft:#1b2436;
  --surface:#111827;
  --surface-2:#19223a;
  --paper:#ffffff;
  --paper-edge:#e7e2d3;
  --gold:#c89a3a;
  --gold-deep:#9c7820;
  --gold-pale:#f4e6c2;
  --line:#0b1220;
  --muted:#64748b;
  --good:#0f7a4d;
  --bad:#be123c;
  --highlight:#fdf2c8;

  --major-color:#be123c;
  --monthly-color:#0f7a4d;
  --demand-color:#6d28d9;
  --price-color:#0369a1;
  --category-text:#1e3a8a;
  --fb-color:#1456b8;
  --cust-color:#be1865;
  --staff-color:#c2540a;
  --groc-color:#157a35;
  --fresh-color:#4d7c0f;
  --bill-color:#3730a3;
  --maint-color:#7a4d0e;
  --sub-color:#9c2bb3;

  --radius-sm:6px;
  --radius-md:10px;
  --radius-lg:16px;
  --serif:'Source Serif 4', Georgia, serif;
  --sans:'Inter', sans-serif;
  --mono:'JetBrains Mono', monospace;
}

*{box-sizing:border-box;}
body{
  font-family:var(--sans);
  background:
    radial-gradient(circle at 15% 0%, #1c2740 0%, transparent 

45%),
    radial-gradient(circle at 85% 100%, #1c2740 0%, 

transparent 40%),
    var(--ink);
  margin:0; padding:18px; color:var(--ink); min-height:100vh;
}

/* ---------- Shell / Nav ---------- */
.tabs-container{ max-width:1080px; margin:0 auto; }
.suite-title{
  display:flex; align-items:baseline; justify-content:space-

between;
  padding:4px 6px 16px; color:#dfe6f5;
}
.suite-title h1{
  font-family:var(--serif); font-weight:700; font-size:22px; 

margin:0; letter-spacing:.2px;
  color:#f3f1e8;
}
.suite-title span{ font-family:var(--mono); font-size:11px; 

letter-spacing:1.5px; text-transform:uppercase; color:var(--

gold); }

.tab-buttons{
  display:flex; gap:6px; margin-bottom:14px; 

background:linear-gradient(180deg,#141d33,#0e1526);
  padding:10px; border-radius:14px; flex-wrap:wrap; border:1px 

solid #243049;
  box-shadow:0 10px 30px -10px rgba(0,0,0,.6), inset 0 1px 0 

rgba(255,255,255,.03);
}
.tab-btn{
  padding:11px 22px; border:none; background:transparent; 

color:#9aa7c3; cursor:pointer;
  border-radius:9px; font-weight:700; font-size:13px; letter-

spacing:.3px; transition:.2s;
  font-family:var(--sans);
}
.tab-btn:hover{ background:#202a45; color:#e7ebf6; }
.tab-btn.active{ background:linear-gradient(180deg,var(--

gold),var(--gold-deep)); color:#241a06; box-shadow:0 4px 14px 

-4px rgba(200,154,58,.6); }
.tab-btn.sub-tab.active{ background:linear-gradient

(180deg,#c24bd6,var(--sub-color)); color:#fff; }
.tab-content{ display:none; }
.tab-content.active{ display:block; }

/* ---------- Admin / Console Panel ---------- */
.admin-panel{
  background:var(--paper); padding:28px; border-radius:var(--

radius-lg);
  box-shadow:0 25px 50px -20px rgba(0,0,0,.55); margin-

bottom:18px;
  border:1px solid #eef0f4; position:relative; 

overflow:hidden;
}
.admin-panel::before{
  content:""; position:absolute; top:0; left:0; right:0; 

height:4px;
  background:linear-gradient(90deg,var(--gold),var(--gold-

deep));
}
.console-head{ display:flex; align-items:center; gap:10px; 

margin-bottom:18px; }
.console-head .tag{
  font-family:var(--mono); font-size:10.5px; letter-

spacing:1.4px; text-transform:uppercase;
  background:var(--ink); color:var(--gold); padding:5px 10px; 

border-radius:5px; font-weight:700;
}
.console-head h2{ margin:0; font-weight:800; color:var(--ink); 

font-size:18px; letter-spacing:-.2px; }

.input-row{ display:grid; grid-template-columns:repeat(auto-

fit,minmax(200px,1fr)); gap:14px; margin-bottom:14px; }
label.field-label{ font-size:10.5px; font-weight:800; text-

transform:uppercase; letter-spacing:.6px; color:var(--muted); 

display:block; margin-bottom:5px; }
textarea{
  width:100%; padding:14px; border:1.5px solid #dfe3ea; 

border-radius:var(--radius-md); font-size:13.5px;
  box-sizing:border-box; font-family:var(--mono); margin-

bottom:14px; resize:vertical; background:#fafbfc;
  transition:.15s;
}
textarea:focus, input:focus, select:focus{ outline:none; 

border-color:var(--gold); box-shadow:0 0 0 3px rgba

(200,154,58,.15); background:#fff; }
input, select{
  width:100%; padding:11px 12px; border:1.5px solid #dfe3ea; 

border-radius:var(--radius-md);
  box-sizing:border-box; font-family:var(--sans); font-

weight:600; font-size:13.5px; background:#fafbfc;
}
.btn-group{ display:flex; gap:9px; flex-wrap:wrap; }
button.action-btn{
  flex:1; padding:14px; border:none; border-radius:var(--

radius-md); font-weight:800; cursor:pointer;
  text-transform:uppercase; min-width:138px; font-size:12px; 

letter-spacing:.3px; transition:.15s;
  box-shadow:0 4px 10px -4px rgba(0,0,0,.25);
}
button.action-btn:hover{ transform:translateY(-1px); 

filter:brightness(1.06); }
button.action-btn:active{ transform:translateY(0); }

.btn-add{ background:linear-gradient(180deg,var(--gold),var

(--gold-deep)); color:#241a06; }
.btn-img{ background:linear-gradient(180deg,#1b2436,var(--

ink)); color:#fff; }
.btn-major{ background:linear-gradient(180deg,#e23a5c,var(--

major-color)); color:#fff; }
.btn-summary{ background:linear-gradient

(180deg,#7c8aa3,#586378); color:#fff; }
.btn-monthly{ background:linear-gradient(180deg,#15a86b,var

(--monthly-color)); color:#fff; }
.btn-demand{ background:linear-gradient(180deg,#8b46e6,var(--

demand-color)); color:#fff; }
.btn-price{ background:linear-gradient(180deg,#0ea5e9,var(--

price-color)); color:#fff; }
.btn-fb{ background:linear-gradient(180deg,#3b82f6,var(--fb-

color)); color:#fff; }
.btn-cust{ background:linear-gradient(180deg,#ec4899,var(--

cust-color)); color:#fff; }
.btn-staff{ background:linear-gradient(180deg,#fb923c,var(--

staff-color)); color:#fff; }
.btn-groc{ background:linear-gradient(180deg,#22c55e,var(--

groc-color)); color:#fff; }
.btn-fresh{ background:linear-gradient(180deg,#84cc16,var(--

fresh-color)); color:#fff; }
.btn-bill{ background:linear-gradient(180deg,#6366f1,var(--

bill-color)); color:#fff; }
.btn-maint{ background:linear-gradient(180deg,#b45309,var(--

maint-color)); color:#fff; }
.btn-sub{ background:linear-gradient(180deg,#d04ee8,var(--

sub-color)); color:#fff; }
.btn-undo{ background:#f59e0b; color:#241a06; font-size:11px; 

padding:10px 16px!important; width:auto!important; flex:none!

important; margin-left:8px; }
.btn-clear{ background:#1b2436; color:#fff; font-size:11px; 

padding:10px 16px!important; width:auto!important; flex:none!

important; margin-left:8px; }
.btn-export-csv{ background:linear-gradient

(180deg,#0f7a4d,#0a5436); color:#fff; }

/* ---------- Report Document (the "PDF" surface) ---------- 

*/
.report-preview-area{
  width:100%; background:var(--paper); padding:0; box-

