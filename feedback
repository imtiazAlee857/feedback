    if (lbEl) {
        const lbMaxComplaints = Math.max(1, ...Object.values

(branchTotals).map(t => t.complaints));
        const ranked = Object.entries(branchTotals)
            .map(([b, t]) => ({ branch: b, complaints: 

t.complaints }))
            .sort((a, b) => a.complaints - b.complaints);
        const medalColors = ['linear-gradient(180deg,var(--

gold),var(--gold-deep))','linear-gradient

(180deg,#22c55e,#0f7a4d)','linear-gradient

(180deg,#fb923c,#c2540a)','linear-gradient

(180deg,#94a3b8,#64748b)'];
        lbEl.innerHTML = ranked.map((r, idx) => {
            const pct = Math.round((r.complaints / 

lbMaxComplaints) * 100);
            const tag = idx === 0 ? '<span class="lb-tag lb-

tag-best">Top Performer</span>' : (idx === ranked.length - 1 

&& totalComplaintsAll > 0 ? '<span class="lb-tag lb-tag-

worst">Needs Focus</span>' : '');
            return `<div class="lb-row${idx===0?' lb-rank-

1':''}">
                <div class="lb-medal lb-${idx+1}">${idx+1}

</div>
                <div class="lb-name">Branch ${r.branch}</div>
                <div class="lb-stats">
                    <div class="lb-bar-wrap"><div class="lb-

bar-fill" style="width:${pct}%; background:${medalColors[idx] 

|| medalColors[3]};"></div></div>
                </div>
                <div class="lb-count">${r.complaints} 

issues</div>
                ${tag}
            </div>`;
        }).join("");
    }

    // Category split (chain-wide)
    const catLabels = { grocery:'Grocery', fresho:'Fresho', 

staff:'Staff', cust:'Customer Sat.', bill:'Billing', 

maint:'Maintenance', demand:'Demand/Stock', price:'Pricing' };
    const catTotalSum = Object.values(categoryTotals).reduce

((a,b) => a+b, 0);
    const splitEl = document.getElementById

('execCategorySplit');
    if (splitEl) {
        if (catTotalSum === 0) {
            splitEl.innerHTML = `<p style="margin:0; font-

size:12px; color:var(--muted); font-weight:600;">No category 

data yet for this period.</p>`;
        } else {
            const rows = Object.entries(categoryTotals)
                .filter(([,v]) => v > 0)
                .sort((a,b) => b[1]-a[1])
                .map(([cat, val]) => [catLabels[cat] || cat, 

Math.round((val/catTotalSum)*100), 'var(--gold-deep)']);
            splitEl.innerHTML = buildPercentBars(rows.length ? 

rows : [['No data', 0, 'var(--muted)']]);
        }
    }

    // Top recurring issues table (cross-branch, sorted by 

branch count then qty) with REASONS shown
    const topIssuesBody = document.getElementById

('execTopIssuesBody');
    const topIssuesEmpty = document.getElementById

('execTopIssuesEmpty');
    const sortedIssues = crossBranchIssues.sort((a,b) => 

(b.branchSet.size - a.branchSet.size) || (b.totalQty - 

a.totalQty)).slice(0, 8);
    if (topIssuesBody) {
        if (sortedIssues.length === 0) {
            topIssuesBody.innerHTML = "";
            if (topIssuesEmpty) 

topIssuesEmpty.classList.remove('hidden');
        } else {
            if (topIssuesEmpty) topIssuesEmpty.classList.add

('hidden');
            topIssuesBody.innerHTML = sortedIssues.map((g, 

idx) => {
                const riskChip = g.branchSet.size >= 4 ? 

'<span class="risk-chip risk-critical">Critical</span>'
                    : g.branchSet.size === 3 ? '<span 

class="risk-chip risk-high">High</span>'
                    : '<span class="risk-chip risk-

watch">Watch</span>';
                const reasonsArr = Array.from(g.reasonsSet);
                let reasonsDisplay = reasonsArr.slice(0, 

3).join("; ");
                if (reasonsArr.length > 3) reasonsDisplay += ` 

+${reasonsArr.length - 3} more`;
                return `<tr ${g.branchSet.size >= 4 ? 

'class="high-complaint-row"' : ''}>
                    <td style="text-align:center;"><span 

class="rank-chip${idx===0?' rank-1':idx===1?' rank-

2':idx===2?' rank-3':''}">${idx+1}</span></td>
                    <td style="font-weight:800;">${g.product}

</td>
                    <td style="text-align:center;">

${g.branchSet.size}/4</td>
                    <td style="text-align:center; font-

weight:900;">${g.totalQty}</td>
                    <td style="text-align:center;">

${riskChip}</td>
                    <td>${reasonsDisplay || '\u2014'}</td>
                </tr>`;
            }).join("");
        }
    }

    // ---- Month-by-month trend chart (uses ALL data, 

ignoring the period filter, so the CEO sees the full trend) 

----
    const trendEl = document.getElementById('execTrendChart');
    if (trendEl) {
        const monthTotals = {}; // 'YYYY-MM' -> qty
        branchIds.forEach(id => {
            const store = globalDataStore[id];
            if (!store || !store.monthly) return;
            store.monthly.forEach(e => {
                if (!e.date) return;
                const parts = e.date.split("/");
                if (parts.length !== 3) return;
                const key = `${parts[2]}-${parts[1]}`;
                monthTotals[key] = (monthTotals[key] || 0) + 

e.qty;
            });
        });
        const sortedMonths = Object.keys(monthTotals).sort

().slice(-6); // last 6 months with data
        if (sortedMonths.length === 0) {
            trendEl.innerHTML = `<p style="margin:0; font-

size:12px; color:var(--muted); font-weight:600;">Not enough 

data yet to chart a trend.</p>`;
        } else {
            const maxVal = Math.max(1, ...sortedMonths.map(m 

=> monthTotals[m]));
            trendEl.innerHTML = sortedMonths.map(m => {
                const [y, mm] = m.split('-');
                const pct = Math.round((monthTotals[m] / 

maxVal) * 100);
                const shortLabel = (monthNames[mm] || 

mm).slice(0,3) + ` '${y.slice(2)}`;
                return `<div class="trend-row">
                    <span class="tlabel">${shortLabel}</span>
                    <span class="tbar-wrap"><span 

class="tbar-fill" style="width:${pct}%;"></span></span>
                    <span class="tval">${monthTotals[m]}

</span>
                </div>`;
            }).join("");
        }
    }

    // ---- Action priorities list ----
    const actionEl = document.getElementById

('execActionList');
    if (actionEl) {
        const actions = [];
        chainWideIssues.slice(0, 3).forEach(g => {
            actions.push(`Investigate <b>"${g.product}"</b> 

with the supplier/process owner \u2014 reported in all 4 

branches (qty ${g.totalQty}).`);
        });
        if (worstBranch !== '\u2014' && worstVal > 0 && 

worstBranch !== bestBranch) {
            actions.push(`<b>${worstBranch}</b> has the 

highest complaint volume this period \u2014 consider a quick 

performance check-in.`);
        }
        if (totalMajorAll > 5) {
            actions.push(`<b>${totalMajorAll}</b> complaints 

are already escalated to Major status \u2014 review the Major 

Complaints page per branch.`);
        }
        const topCat = Object.entries(categoryTotals).sort

((a,b)=>b[1]-a[1])[0];
        if (topCat && topCat[1] > 0) {
            const catLabelMap = { grocery:'Grocery', 

fresho:'Fresho', staff:'Staff', cust:'Customer Satisfaction', 

bill:'Billing', maint:'Maintenance', demand:'Demand/Stock', 

price:'Pricing' };
            actions.push(`<b>${catLabelMap[topCat[0]] || 

topCat[0]}</b> is the single largest complaint category this 

period (qty ${topCat[1]}) \u2014 prioritize this area in the 

next review.`);
        }
        if (crossBranchIssues.length > chainWideIssues.length) 

{
            const spreading = crossBranchIssues.length - 

chainWideIssues.length;
            actions.push(`<b>${spreading}</b> issue(s) are 

spreading across 2-3 branches but haven't hit all 4 yet \u2014 

early intervention can stop them from going chain-wide.`);
        }
        actionEl.innerHTML = actions.slice(0, 5).map(a => 

`<li>${a}</li>`).join("");
    }

    // Insight banner: plain-language auto summary for the CEO
    const insightEl = document.getElementById

('execInsightBanner');
    if (insightEl) {
        if (totalComplaintsAll === 0) {
            insightEl.innerHTML = `<b>No data logged yet</b> 

for this period. Add branch reports to see chain-wide insights 

here.`;
        } else {
            const topIssue = sortedIssues[0];
            let msg = `<b>${totalComplaintsAll} complaints</b> 

logged chain-wide across <b>${allDaysSet.size} day(s)</b>, 

with <b>${totalMajorAll}</b> escalated to Major status. `;
            if (topIssue) {
                msg += `The most urgent pattern is 

<b>"${topIssue.product}"</b>, independently reported by <b>

${topIssue.branchSet.size} of 4 branches</b> \u2014 this 

points to a supplier or chain-wide process issue rather than a 

single store's fault. `;
            }
            msg += `<b>${bestBranch}</b> is currently the 

best-performing branch with the fewest logged complaints.`;
            insightEl.innerHTML = msg;
        }
    }
}

boot();
</script>
</body>
</html>
