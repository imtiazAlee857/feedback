  white-space:nowrap; transform:rotate(-28deg); letter-

spacing:2px;
}
.report-preview-area::before{
  content:""; position:absolute; top:0; left:0; right:0; 

height:9px;
  background:linear-gradient(90deg,var(--accent,var(--

