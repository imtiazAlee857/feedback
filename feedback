/* 

============================================================
   DATA LAYER  unchanged persistence logic (localStorage)
   

============================================================ 

*/
const STORAGE_VERSION = "branch_data_v2_";
const globalDataStore = {};

function saveBranchToLocalStorage(branchId) {
    if (globalDataStore[branchId]) {
        localStorage.setItem(STORAGE_VERSION + branchId, 

JSON.stringify(globalDataStore[branchId]));
    }
}

function loadBranchFromLocalStorage(branchId) {
    const saved = localStorage.getItem(STORAGE_VERSION + 

branchId);
    const defaultCategories = {
        monthly: [], major: [], demand: [], price: [], cust: 

[], staff: [], grocery: [], fresho: [], bill: [], maint: []
    };
    if (saved) {
        try {
            const parsed = JSON.parse(saved);
            for (let key in defaultCategories) {
                if (!parsed[key]) parsed[key] = [];
            }
            globalDataStore[branchId] = parsed;
        } catch(e) { globalDataStore[branchId] = 

seedBranchDefaults(branchId, defaultCategories); }
    } else {
        globalDataStore[branchId] = seedBranchDefaults

(branchId, defaultCategories);
    }
}

function seedBranchDefaults(branchId, defaultCategories) {
    const seed = DEFAULT_BRANCH_DATA[branchId];
    if (!seed) return { ...defaultCategories };
    const merged = { ...defaultCategories };
    for (let key in defaultCategories) {
        merged[key] = Array.isArray(seed[key]) ? seed[key] : 

[];
    }
    return merged;
}

function getFbData(pageType) {
    const raw = localStorage.getItem(`fb_${pageType}_data`);
    if (raw !== null) {
        try { return JSON.parse(raw); } catch(e) { /* fall 

through to default */ }
    }
    return (DEFAULT_FB_DATA[pageType] || []).slice();
}

function initStoreForBranch(branchId) {
    if (!globalDataStore[branchId]) {
        loadBranchFromLocalStorage(branchId);
    }
}

function refreshAllBranchViews(branchId) {
    if (!globalDataStore[branchId]) return;
    renderGroupedMonthlyTable(branchId);
    renderAllTables(branchId);
    renderSubComplaints();
