}
.major-area::before{ background:linear-gradient

(90deg,#e23a5c,var(--major-color)); }
.monthly-area::before{ background:linear-gradient

(90deg,#15a86b,var(--monthly-color)); }
.demand-area::before{ background:linear-gradient

(90deg,#8b46e6,var(--demand-color)); }
.price-area::before{ background:linear-gradient

(90deg,#0ea5e9,var(--price-color)); }
.fb-area::before{ background:linear-gradient

(90deg,#3b82f6,var(--fb-color)); }
.cust-area::before{ background:linear-gradient

(90deg,#ec4899,var(--cust-color)); }
.staff-area::before{ background:linear-gradient

(90deg,#fb923c,var(--staff-color)); }
.groc-area::before{ background:linear-gradient

(90deg,#22c55e,var(--groc-color)); }
.fresh-area::before{ background:linear-gradient

(90deg,#84cc16,var(--fresh-color)); }
.bill-area::before{ background:linear-gradient

(90deg,#6366f1,var(--bill-color)); }
.maint-area::before{ background:linear-gradient

(90deg,#b45309,var(--maint-color)); }
.sub-area::before{ background:linear-gradient

(90deg,#d04ee8,var(--sub-color)); }

.report-header{
  display:flex; justify-content:space-between; align-

items:flex-start;
  border-bottom:3px double var(--ink); margin-bottom:18px; 

padding-bottom:14px; gap:16px;
}
.report-header .htext{ flex:1; }
.report-header .eyebrow{
  font-family:var(--mono); font-size:10px; letter-spacing:2px; 

text-transform:uppercase;
  color:var(--gold-deep); font-weight:700; margin-bottom:4px; 

display:block;
}
.report-header h1{
  margin:0; font-size:24px; font-weight:700; color:var(--ink); 

letter-spacing:-.3px; font-family:var(--serif);
  line-height:1.15;
}
.report-header .sub-line{ font-size:11.5px; color:var(--

muted); font-weight:600; margin-top:4px; }

/* Document reference block  replaces the old circular seal */
.doc-ref{
  flex-shrink:0; text-align:right; padding-left:18px; border-

left:1.5px solid #e7eaf0;
  min-width:128px;
}
.doc-ref .ref-code{
  font-family:var(--mono); font-size:12.5px; font-weight:700; 

