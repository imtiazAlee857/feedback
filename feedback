function normalizeText(str) { if (!str) return ""; let txt = 

str.trim().toLowerCase(); return txt.charAt(0).toUpperCase() + 

txt.slice(1); }

// Helper to parse DD/MM/YYYY to Date object for strict 

sorting
function parseCustomDate(dateStr) {
    if(!dateStr) return new Date(0);
    const parts = dateStr.split("/");
    if(parts.length === 3) {
        return new Date(parts[2], parts[1] - 1, parts[0]);
    }
    return new Date(dateStr);
}

// Extract MM from a DD/MM/YYYY string
function getMonthFromDateStr(dateStr) {
    if(!dateStr) return null;
    const parts = dateStr.split("/");
    if(parts.length === 3) return parts[1];
    return null;
}

// Generic month filter: returns true if item's date matches 

the chosen month ('all' = no filter)
function matchesMonth(dateStr, monthVal) {
    if(!monthVal || monthVal === 'all') return true;
    return getMonthFromDateStr(dateStr) === monthVal;
}

function processData(id) {
    initStoreForBranch(id);
    const heading = document.getElementById(`branchInput_

${id}`).value || "ANALYSIS REPORT";
    const rawDate = document.getElementById(`dateInput_${id}

`).value;
    const totalFb = parseInt(document.getElementById

(`totalFeedbackInput_${id}`).value) || 0;
    const bulkText = document.getElementById(`bulkInput_${id}

`).value;
    const remarks = document.getElementById

(`goodCommentsInput_${id}`).value;
    if (!rawDate) { alert("Please select a date!"); return; }
    if (bulkText.trim() === "") { alert("Please input 

complaints data!"); return; }
    const formattedDate = rawDate.split("-").reverse().join

("/");
    document.getElementById(`mainHeading_${id}`).innerText = 

heading;
    document.getElementById(`outDate_${id}`).innerText = 

formattedDate;
    document.getElementById(`outTotalAll_${id}`).innerText = 

totalFb;
    document.getElementById(`outGoodComments_${id}`).innerText 

= remarks || "...";
    const refCodeEl = document.getElementById(`refCode_${id}

`);
    if (refCodeEl) refCodeEl.innerText = `RPT\u00B7B

${getBranchNum(id)}\u00B7${rawDate.replace(/-/g, "")}`;
    const tbody = document.getElementById(`tableBody_${id}`); 

tbody.innerHTML = "";
    const lines = bulkText.split("\n");
    let categoriesOrder = [], dataMap = {};
    let currentCategory = "", grocCount = 0, freshCount = 0, 

otherCount = 0;
    lines.forEach(line => {
        let cleanLine = line.trim();
        if (!cleanLine) return;
        if (!cleanLine.includes(".") && !cleanLine.includes

("-") && !cleanLine.match(/^\d/)) {
            currentCategory = normalizeText(cleanLine);
            if (!categoriesOrder.includes(currentCategory)) 

categoriesOrder.push(currentCategory);
            if (!dataMap[currentCategory]) dataMap

[currentCategory] = {};
            return;
        }
        cleanLine = cleanLine.replace(/^[-*\d]+\s*/, '');
        let productPart = "", reasonPart = "";
        if (cleanLine.includes(".")) {
            let dotIdx = cleanLine.indexOf(".");
            productPart = normalizeText(cleanLine.substring(0, 

dotIdx));
            reasonPart = normalizeText(cleanLine.substring

(dotIdx+1));
        } else { productPart = normalizeText(cleanLine); 

reasonPart = "General issue"; }
        if (!currentCategory) { currentCategory = "Others"; if 

(!categoriesOrder.includes(currentCategory)) 

categoriesOrder.push(currentCategory); if (!dataMap

[currentCategory]) dataMap[currentCategory] = {}; }
        let catLower = currentCategory.toLowerCase();
        if(catLower.includes("grocery") || catLower.includes

("groc")) grocCount++;
        else if(catLower.includes("fresho") || 

catLower.includes("fresh")) freshCount++;
        else otherCount++;
        let key = `${productPart.toLowerCase()}||

${reasonPart.toLowerCase()}`;
        if (dataMap[currentCategory][key]) dataMap

[currentCategory][key].qty += 1;
        else dataMap[currentCategory][key] = { qty:1, 

originalProduct: productPart, originalReason: reasonPart };
    });
    let totalIssuesCount = 0;
    for (let category of categoriesOrder) {
        const combos = dataMap[category];
        if (!combos || Object.keys(combos).length === 0) 

continue;
        const productGroups = new Map();
        for (let combo of Object.values(combos)) {
            const prodNorm = 

combo.originalProduct.toLowerCase();
            if (!productGroups.has(prodNorm)) 

productGroups.set(prodNorm, { product: combo.originalProduct, 

totalQty: 0, reasonsSet: new Set() });
            const group = productGroups.has(prodNorm) ? 

productGroups.get(prodNorm) : null;
            group.totalQty += combo.qty;
            group.reasonsSet.add(combo.originalReason);
            totalIssuesCount += combo.qty;

            globalDataStore[id].monthly.push({ date: 

formattedDate, product: combo.originalProduct, qty: combo.qty, 

reason: combo.originalReason });
            let routeData = { product: combo.originalProduct, 

qty: combo.qty, reason: combo.originalReason };
            let reasonLow = combo.originalReason.toLowerCase

(), catLow = category.toLowerCase();
            const pricePhrases = ["price expensive", "prices 

expensive", "price diff", "price issue", "price tags issue"];
            let isPrice = pricePhrases.some(p => 

reasonLow.includes(p));

            if (isPrice) globalDataStore[id].price.push({ 

date: formattedDate, ...routeData });
            else if (reasonLow.includes("unavailable") || 

reasonLow.includes("short") || reasonLow.includes("magwai")) 

globalDataStore[id].demand.push({ date: formattedDate, 

...routeData });
            else if (catLow.includes("grocery") || 

catLow.includes("groc")) globalDataStore[id].grocery.push({ 

date: formattedDate, ...routeData });
            else if (catLow.includes("fresho") || 

catLow.includes("fresh")) globalDataStore[id].fresho.push({ 

date: formattedDate, ...routeData });
            else if (catLow.includes("staff")) 

globalDataStore[id].staff.push({ date: formattedDate, 

...routeData });
            else if (catLow.includes("maintenance") || 

catLow.includes("maint")) globalDataStore[id].maint.push({ 

date: formattedDate, ...routeData });
            else if (catLow.includes("satisfaction") || 

catLow.includes("sat") || combo.originalProduct.toLowerCase

().includes("customer")) globalDataStore[id].cust.push({ date: 

formattedDate, ...routeData });
            else if (catLow.includes("billing") || 

catLow.includes("bill")) globalDataStore[id].bill.push({ date: 

formattedDate, ...routeData });
        }
        tbody.innerHTML += `<tr class="category-heading"><td 

colspan="3">${category} Complaints</td></tr>`;
        for (let group of productGroups.values()) {
            let reasonsArray = Array.from(group.reasonsSet);
            let displayReasons = reasonsArray.slice(0,4).join

("; ");
            if (reasonsArray.length > 4) displayReasons += ` 

+${reasonsArray.length-4} more`;
            let highlightClass = group.totalQty > 2 ? 

'class="high-complaint-row"' : '';
            tbody.innerHTML += `<tr ${highlightClass}><td 

style="font-weight:800;">${group.product}</td><td 

style="text-align:center; font-weight:900; color:var(--gold-

deep);">${group.totalQty}</td><td>${displayReasons}

</td></tr>`;

            if (group.totalQty > 2) {
                globalDataStore[id].major.push({ date: 

formattedDate, product: group.product, qty: group.totalQty, 

reason: displayReasons });
            }
        }
    }
    document.getElementById(`outTotalComplaints_${id}

`).innerText = totalIssuesCount;
    const score = totalFb > 0 ? Math.round(((totalFb - 

totalIssuesCount)/totalFb)*100) : 100;
    document.getElementById(`outSatRate_${id}`).innerText = `

${score}%`;
    let grossSum = grocCount+freshCount+otherCount;
    let grocPercent = grossSum?Math.round

((grocCount/grossSum)*100):0, freshPercent = grossSum?

Math.round((freshCount/grossSum)*100):0, otherPercent = 

grossSum?Math.round((otherCount/grossSum)*100):0;
    document.getElementById(`percentageList_${id}`).innerHTML 

= buildPercentBars([
        ['Grocery Complaints', grocPercent, 'var(--groc-

color)'],
        ['Fresho Complaints', freshPercent, 'var(--fresh-

color)'],
        ['Others Complaints', otherPercent, 'var(--muted)']
    ]);
    saveBranchToLocalStorage(id);
    refreshAllBranchViews(id);
    renderExecOverview();
    renderSubComplaints();
    alert("Report processed! Yellow highlighted rows have been 

pushed to Major page successfully.");
}

